# Local development bootstrap values only.
# Application connection strings and service credentials must come from Vault.

# -----------------------------
# Vault bootstrap
# -----------------------------
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root
VAULT_APP_SECRET_PATH=secret/data/concierge/app
VAULT_TIMEOUT_SECONDS=5

# -----------------------------
# Local service ports
# These are not app secrets.
# -----------------------------
API_PORT=8000
ADMIN_PORT=8501
MODEL_SERVER_PORT=8010
GUARDRAILS_PORT=8020
WIDGET_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001