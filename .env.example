# Local development bootstrap values only.
# Application connection strings and service credentials must come from Vault.

# -----------------------------
# Vault bootstrap
# -----------------------------
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root
VAULT_APP_SECRET_PATH=secret/data/concierge/app
VAULT_TIMEOUT_SECONDS=5

# -----------------------------
# Admin authentication
# -----------------------------
# HS256 signing key for the admin JWT. REQUIRED in staging/prod.
# Local dev defaults to a hardcoded value inside app/services/admin_settings.py
# so pytest runs without env wiring.
ADMIN_JWT_SECRET=dev-only-do-not-ship-admin-cccccccccccccccccccccccccc
# Admin session lifetime in seconds (default 28800 = 8 hours). No refresh —
# re-login is required after expiry.
ADMIN_TOKEN_TTL_SECONDS=28800
# Set CONCIERGE_ENV=prod (or anything != "dev") to close the dev-headers
# fallback in require_tenant_admin so only the admin JWT path authenticates.
CONCIERGE_ENV=dev
# Backend URL the admin Streamlit app uses to call the API.
# Inside docker compose, the api service is reachable at http://api:8000;
# for local-host development (Streamlit outside docker), use http://localhost:8000.
CONCIERGE_BACKEND_URL=http://api:8000

# -----------------------------
# Widget backend
# -----------------------------
# "memory" (default): in-process repo seeded with the demo widget fixture.
#                     Fast for tests; state survives the process but not restart.
# "sql":              backed by the widget_configs table (migration 0004).
#                     Requires a real Postgres connection + a seeded row
#                     (see scripts/seed_widget_config.py). Flip to "sql" once
#                     the demo widget row is in the DB.
WIDGET_REPO_BACKEND=memory

# -----------------------------
# Local service ports
# These are not app secrets.
# -----------------------------
API_PORT=8000
ADMIN_PORT=8501
MODEL_SERVER_PORT=8010
GUARDRAILS_PORT=8020
WIDGET_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
PGADMIN_PORT=5050

# -----------------------------
# pgAdmin (dev only)
# Default credentials unlock the local pgAdmin UI on first boot.
# Change these before exposing the port anywhere other than localhost.
# -----------------------------
PGADMIN_DEFAULT_EMAIL=admin@concierge.dev
PGADMIN_DEFAULT_PASSWORD=admin