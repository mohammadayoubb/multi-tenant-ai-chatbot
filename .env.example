# Local development values only.
# Real secrets must be resolved from Vault in production-style flows.

# -----------------------------
# Vault
# -----------------------------
VAULT_ROOT_TOKEN=root
VAULT_ADDR=http://vault:8200

# -----------------------------
# Ports
# -----------------------------
API_PORT=8000
ADMIN_PORT=8501
MODEL_SERVER_PORT=8010
GUARDRAILS_PORT=8020
WIDGET_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------
# Database / storage
# -----------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/concierge
SYNC_DATABASE_URL=postgresql://postgres:postgres@db:5432/concierge
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=minio:9000

# -----------------------------
# Internal service URLs
# -----------------------------
MODEL_SERVER_URL=http://modelserver:8010
GUARDRAILS_URL=http://guardrails:8020

# -----------------------------
# Service-to-service credentials
# Local demo values only.
# In the final version these should come from Vault.
# -----------------------------
MODELSERVER_SERVICE_TOKEN=local-modelserver-token
GUARDRAILS_SERVICE_TOKEN=local-guardrails-token

# -----------------------------
# Widget / memory settings
# -----------------------------
WIDGET_TOKEN_TTL_SECONDS=900

# 1800 seconds = 30 minutes.
# This is short-term visitor memory, not permanent conversation storage.
SESSION_MEMORY_TTL_SECONDS=1800